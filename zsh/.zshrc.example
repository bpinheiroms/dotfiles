# Base system paths
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:$PATH"

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home
ZSH_THEME="robbyrussell"
plugins=(git)
source $ZSH/oh-my-zsh.sh

# Local binaries
export PATH="$PATH:$HOME/.local/bin"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# Volta / Node tooling
export VOLTA_HOME="$HOME/.volta"
export PATH="$VOLTA_HOME/bin:$PATH"
export NI_CONFIG_FILE="$HOME/.config/ni/nirc"

# Go
export GOPATH="$HOME/go"
export PATH="$PATH:$GOPATH/bin"

# Android
export ANDROID_HOME="$HOME/Library/Android/sdk"
export PATH="$PATH:$ANDROID_HOME/emulator"
export PATH="$PATH:$ANDROID_HOME/platform-tools"

# Bun
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Google Cloud SDK
if [ -f "$HOME/google-cloud-sdk/path.zsh.inc" ]; then . "$HOME/google-cloud-sdk/path.zsh.inc"; fi
if [ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ]; then . "$HOME/google-cloud-sdk/completion.zsh.inc"; fi

# OpenCode
export PATH="$HOME/.opencode/bin:$PATH"

# Maestro
export PATH="$HOME/.maestro/bin:$PATH"

# Vite+
. "$HOME/.vite-plus/env"

# Force full colors in cmux/Ghostty sessions and run Droid from a fresh login shell.
if [ "$TERM" = "dumb" ]; then
  export TERM=xterm-256color
fi
export COLORTERM=truecolor
export FORCE_COLOR=3
export CLICOLOR=1

droid() {
  if [ -z "$DROID_LOGIN_SHELL_ACTIVE" ]; then
    DROID_LOGIN_SHELL_ACTIVE=1 zsh -lic 'TERM=xterm-256color COLORTERM=truecolor FORCE_COLOR=3 CLICOLOR=1 command droid "$@"' droid "$@"
  else
    TERM=xterm-256color COLORTERM=truecolor FORCE_COLOR=3 CLICOLOR=1 command droid "$@"
  fi
}

# Local secrets and machine-specific overrides
if [ -f "$HOME/.zshrc.local" ]; then
  . "$HOME/.zshrc.local"
fi
