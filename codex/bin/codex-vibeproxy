#!/usr/bin/env bash
set -euo pipefail

models_string="${CODEX_VIBEPROXY_MODELS:-gpt-5.5 gpt-5.4 gpt-5.4-mini}"
read -r -a models <<< "$models_string"

if [[ ${#models[@]} -eq 0 ]]; then
  echo "codex-vibeproxy: no models configured" >&2
  exit 1
fi

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/codex"
state_file="$state_dir/vibeproxy-model-index"
mkdir -p "$state_dir"

index=0
if [[ -f "$state_file" ]]; then
  stored_index="$(cat "$state_file")"
  if [[ "$stored_index" =~ ^[0-9]+$ ]]; then
    index="$stored_index"
  fi
fi

model="${models[$((index % ${#models[@]}))]}"
next_index="$(((index + 1) % ${#models[@]}))"
printf '%s' "$next_index" > "$state_file"

echo "codex-vibeproxy: using $model" >&2
exec command codex -c 'model_provider="vibeproxy"' -m "$model" "$@"
